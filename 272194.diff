--- mail/dovecot24-pigeonhole/Makefile	1970-01-01 02:00:00.000000000 +0200
+++ mail/dovecot24-pigeonhole/Makefile	2026-06-27 23:30:21.947894000 +0300
@@ -0,0 +1,58 @@ 
+PORTNAME=	pigeonhole
+DISTVERSION=	2.4.4
+CATEGORIES=	mail
+MASTER_SITES=	https://pigeonhole.dovecot.org/releases/2.4/
+PKGNAMEPREFIX=	dovecot24-
+DISTNAME=	dovecot-pigeonhole-${DISTVERSION}
+
+MAINTAINER=	jordan@ostreff.info
+COMMENT=	Sieve plugin for the Dovecot '2.4' IMAP and POP3 server
+WWW=		https://pigeonhole.dovecot.org/
+
+LICENSE=	LGPL21
+LICENSE_FILE=	${WRKSRC}/COPYING.LGPL
+
+# Prevent installation if the old pigeonhole port (for Dovecot 2.3) is present
+CONFLICTS_INSTALL=	dovecot-pigeonhole
+
+# Strict dependencies on the new Dovecot 2.4 framework
+BUILD_DEPENDS=	dovecot24>=2.4.4:mail/dovecot24
+RUN_DEPENDS=	dovecot24>=2.4.4:mail/dovecot24
+
+USES=		cpe libtool localbase python:build,test
+CPE_VENDOR=	dovecot
+CPE_PRODUCT=	pigeonhole
+USE_LDCONFIG=	${PREFIX}/lib/dovecot
+
+GNU_CONFIGURE=	yes
+GNU_CONFIGURE_MANPREFIX=	${PREFIX}/share
+
+# Point configure to the system dovecot-config path
+CONFIGURE_ARGS=	--with-dovecot=${LOCALBASE}/lib/dovecot
+
+INSTALL_TARGET=	install-strip
+
+OPTIONS_DEFINE=		DOCS EXAMPLES LDAP MANAGESIEVE
+OPTIONS_DEFAULT=	DOCS MANAGESIEVE
+OPTIONS_SUB=		yes
+
+LDAP_USES=			ldap
+LDAP_CONFIGURE_WITH=		ldap
+MANAGESIEVE_CONFIGURE_WITH=	managesieve
+
+.include <bsd.port.options.mk>
+
+# Pre-build guard: Ensure the currently installed active dovecot is version 2.4
+pre-everything::
+	@if [ -f ${LOCALBASE}/sbin/dovecot ]; then \
+		DOV_VER=$$(${LOCALBASE}/sbin/dovecot --version | cut -d. -f1-2); \
+		if [ "$$DOV_VER" != "2.4" ]; then \
+			${ECHO_MSG} "=========================================================================="; \
+			${ECHO_MSG} "ERROR: Detected Dovecot version $$DOV_VER installed in the system."; \
+			${ECHO_MSG} "This port requires dovecot24. Please uninstall the old version first."; \
+			${ECHO_MSG} "=========================================================================="; \
+			${FALSE}; \
+		fi \
+	fi
+
+.include <bsd.port.mk>
